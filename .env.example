# Copy this file to .env for local testing.
# On Render, set these as Environment Variables in the dashboard instead
# (never commit a real .env file).

# Get this from Supabase: Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.supabase.co:5432/postgres

# A long random string only you know. Used to view/export registrations.
ADMIN_KEY=change-this-to-a-long-random-secret

# Your live website's origin (no trailing slash). Use * only while testing.
ALLOWED_ORIGIN=*

PORT=3000
